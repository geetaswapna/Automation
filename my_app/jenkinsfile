pipeline {

    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/geetaswapa/automation.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t geetaswapna/my-nginx:${BUILD_NUMBER} .'
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {

                    sh '''
                    docker login -u $USER -p $PASS
                    '''
                }
            }
        }

        stage('Push Image') {
            steps {
                sh 'docker push geetaswapna/my-nginx:${BUILD_NUMBER}'
            }
        }

    }
}
